{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EduPortal_Control",
  "version": "0.2.9",
  "identifier": "com.eduportal.control.vpsmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EduPortal_Control VPS Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "resources": [
      "resources/caddy/caddy_windows_amd64.zip",
      "resources/caddy/caddy_windows_amd64.json"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3RTY5NjhGQjAzREYwRUQKUldUdDhEMndqNWJtZC9DMWJ1d04vclZYZFZTc1dDM0VrMmwwM3JDSDJBSGJVMWRNV1YrK1hZa3IK",
      "endpoints": [
        "https://github.com/nguyenhnhatquang/EduPortal_Control/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
